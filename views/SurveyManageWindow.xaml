<Window x:Class="UQuiz.views.SurveyManageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:UQuiz.converters"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>

        <SolidColorBrush x:Key="PrimaryBrush" Color="#3F51B5"/>
        <SolidColorBrush x:Key="SidebarBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#FAFAFA"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#E0E0E0"/>

        <Style x:Key="HeaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#32408F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource HeaderButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#424242"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="16,0,0,0"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F0F0F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BackgroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" MouseLeftButtonDown="Border_MouseLeftButtonDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                        <TextBlock Text="UQuiz" Foreground="White" FontSize="13" FontWeight="Bold"/>
                        <TextBlock Text="| Управление опросом" Foreground="#C5CAE9" FontSize="11" 
                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="&#xE921;" Style="{StaticResource HeaderButtonStyle}"
                                Command="{Binding MinimizeCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"/>
                        <Button Content="&#xE711;" Style="{StaticResource CloseButtonStyle}"
                                Command="{Binding CloseCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Background="{StaticResource SidebarBrush}" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
                    <StackPanel>
                        <Border Padding="16" Margin="0,16,0,8">
                            <StackPanel>
                                <TextBlock Text="{Binding SurveyTitle}" FontSize="15" FontWeight="SemiBold" 
                                           Foreground="#212121" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Height="1" Background="#E0E0E0" Margin="12,0"/>

                        <StackPanel Margin="12,16">
                            <Button Content="Отправка" Style="{StaticResource MenuButtonStyle}" 
                                    Command="{Binding NavigateCommand}" CommandParameter="Send"/>
                            <Button Content="Проверка" Style="{StaticResource MenuButtonStyle}" 
                                    Command="{Binding NavigateCommand}" CommandParameter="Check"/>
                        </StackPanel>

                        <Border Height="1" Background="#E0E0E0" Margin="12,8"/>

                        <Button Content="Назад к опросам" Style="{StaticResource MenuButtonStyle}" 
                                Margin="12,16" 
                                Command="{Binding BackCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"/>
                    </StackPanel>
                </Border>

                <Grid Grid.Column="1" Background="{StaticResource BackgroundBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Padding="24,20,24,16">
                        <TextBlock Text="{Binding SelectedSection}" FontSize="20" 
                                   FontWeight="SemiBold" Foreground="#212121"/>
                    </Border>

                    <ContentControl Grid.Row="1" Content="{Binding SelectedSection}">
                        <ContentControl.Resources>
                            <DataTemplate x:Key="Send">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <Border Padding="24">
                                        <StackPanel MaxWidth="700">
                                            <TextBlock Text="Отправка опроса ученикам" FontSize="16" FontWeight="SemiBold" 
                                                       Foreground="#212121" Margin="0,0,0,20"/>

                                            <CheckBox Content="Отправить всем прикреплённым ученикам" 
                                                      IsChecked="{Binding DataContext.SendToAll, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}" 
                                                      FontWeight="SemiBold" Margin="0,0,0,15"/>

                                            <StackPanel Visibility="{Binding DataContext.SendToAll, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBlock Text="Фильтр по классу:" Margin="0,0,0,5"/>
                                                <ComboBox ItemsSource="{Binding DataContext.AvailableClasses, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}" 
                                                          SelectedItem="{Binding DataContext.SelectedClass, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}" 
                                                          Height="32" Margin="0,0,0,20"/>
                                            </StackPanel>

                                            <StackPanel Visibility="{Binding DataContext.IsManualSelectionEnabled, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                    <Button Content="Выбрать всех" Width="120" Height="30" Margin="0,0,10,0"
                                                            Background="#3F51B5" Foreground="White" BorderThickness="0" Cursor="Hand"
                                                            Command="{Binding DataContext.SelectAllCommand, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}">
                                                        <Button.Resources>
                                                            <Style TargetType="Border">
                                                                <Setter Property="CornerRadius" Value="4"/>
                                                            </Style>
                                                        </Button.Resources>
                                                    </Button>
                                                    <Button Content="Снять выбор" Width="120" Height="30"
                                                            Background="Transparent" Foreground="#757575" BorderBrush="#E0E0E0" BorderThickness="1" Cursor="Hand"
                                                            Command="{Binding DataContext.DeselectAllCommand, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}">
                                                        <Button.Resources>
                                                            <Style TargetType="Border">
                                                                <Setter Property="CornerRadius" Value="4"/>
                                                            </Style>
                                                        </Button.Resources>
                                                    </Button>
                                                </StackPanel>

                                                <TextBlock Text="Список учеников:" FontWeight="SemiBold" Margin="0,0,0,10"/>

                                                <ItemsControl ItemsSource="{Binding DataContext.AttachedStudents, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <CheckBox IsChecked="{Binding IsSelected}" Margin="0,3">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                                                    <TextBlock Text=" (" />
                                                                    <TextBlock Text="{Binding Email}" Foreground="#757575"/>
                                                                    <TextBlock Text=")" />
                                                                    <TextBlock Text="{Binding Class, StringFormat=' - {0}'}" 
                                                                               Foreground="#3F51B5" Margin="5,0,0,0"/>
                                                                </StackPanel>
                                                            </CheckBox>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>

                                            <TextBlock Text="{Binding DataContext.Message, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}" 
                                                       Foreground="#4CAF50" Margin="0,15,0,0"/>

                                            <Button Content="Отправить опрос" Width="160" Height="40" Margin="0,20,0,0"
                                                    Background="#3F51B5" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"
                                                    Command="{Binding DataContext.SendSurveyCommand, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}">
                                                <Button.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="4"/>
                                                    </Style>
                                                </Button.Resources>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </ScrollViewer>
                            </DataTemplate>

                            <DataTemplate x:Key="Check">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="350"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Список учеников -->
                                    <Border Grid.Column="0" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0" Background="White">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <StackPanel>
                                                <TextBlock Text="Ответы учеников" FontWeight="SemiBold" FontSize="16" Margin="15"/>
                                                <ItemsControl ItemsSource="{Binding DataContext.StudentResponses, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" 
                                        Padding="12" Margin="10,5" Background="#FAFAFA" Cursor="Hand"
                                        MouseLeftButtonUp="ResponseItem_Click" Tag="{Binding}">
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding StudentName}" FontWeight="SemiBold" FontSize="14"/>
                                                                    <TextBlock Text="{Binding StudentEmail}" FontSize="11" Foreground="#757575"/>
                                                                    <TextBlock Text="{Binding StudentClass, StringFormat='Класс: {0}'}" FontSize="11" Foreground="#3F51B5"/>
                                                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                                        <TextBlock Text="{Binding CompletedDate, StringFormat='Сдан: {0:dd.MM.yyyy HH:mm}'}" FontSize="11" Foreground="#9E9E9E"/>
                                                                        <TextBlock Text="{Binding TotalScore, StringFormat='Баллы: {0}'}" FontSize="11" 
                                                       Foreground="#4CAF50" FontWeight="SemiBold" Margin="10,0,0,0"/>
                                                                    </StackPanel>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Border>

                                    <!-- Детали ответа -->
                                    <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                                        <Border Padding="20">
                                            <StackPanel>
                                                <TextBlock Text="Выберите ученика для проверки" FontSize="16" Foreground="#757575"
                               Visibility="{Binding DataContext.SelectedResponseDetail, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}"/>

                                                <TextBlock Text="{Binding DataContext.CheckMessage, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}" 
                               Foreground="#4CAF50" Margin="0,0,0,15"/>

                                                <ItemsControl ItemsSource="{Binding DataContext.SelectedResponseDetail.Answers, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" 
                                        Padding="15" Margin="0,0,0,10" Background="White">
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding QuestionText}" FontWeight="SemiBold" Margin="0,0,0,10" TextWrapping="Wrap"/>
                                                                    <TextBlock Text="{Binding Points, StringFormat='Макс. балл: {0}'}" FontSize="12" Foreground="#FF9800"/>

                                                                    <!-- Текстовый ответ -->
                                                                    <Border Background="#F5F5F5" Padding="10" CornerRadius="4" Margin="0,8,0,0"
                                                Visibility="{Binding StudentAnswer, Converter={StaticResource StringToVisibilityConverter}}">
                                                                        <TextBlock Text="{Binding StudentAnswer}" TextWrapping="Wrap"/>
                                                                    </Border>

                                                                    <!-- Выбранные варианты -->
                                                                    <ItemsControl ItemsSource="{Binding SelectedOptionTexts}" Margin="0,5,0,0">
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <TextBlock Text="{Binding ., StringFormat='• {0}'}" FontSize="13" Margin="0,2"/>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>

                                                                    <!-- Оценка -->
                                                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                                        <TextBlock Text="Баллы:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                                        <TextBox Text="{Binding Score, UpdateSourceTrigger=PropertyChanged}" 
                                                     Width="60" Height="28" Padding="5,4"
                                                     BorderBrush="#E0E0E0" BorderThickness="1"/>
                                                                        <TextBlock Text="{Binding Points, StringFormat=' / {0}'}" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                                                    </StackPanel>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <Button Content="Сохранить оценки" Width="150" Height="40" Margin="0,20,0,0"
                            Background="#4CAF50" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"
                            Command="{Binding DataContext.SaveScoreCommand, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"/>
                                            </StackPanel>
                                        </Border>
                                    </ScrollViewer>
                                </Grid>
                            </DataTemplate>
                        </ContentControl.Resources>

                        <ContentControl.Style>
                            <Style TargetType="ContentControl">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSection}" Value="Send">
                                        <Setter Property="ContentTemplate" Value="{StaticResource Send}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedSection}" Value="Check">
                                        <Setter Property="ContentTemplate" Value="{StaticResource Check}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ContentControl.Style>
                    </ContentControl>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>