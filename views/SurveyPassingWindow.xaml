<Window x:Class="UQuiz.views.SurveyPassingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:UQuiz.converters"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Height="600" Width="800">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <SolidColorBrush x:Key="PrimaryBrush" Color="#FF9800"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#FAFAFA"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#E0E0E0"/>

        <DropShadowEffect x:Key="WindowShadow" BlurRadius="20" ShadowDepth="0" Opacity="0.25" Color="Black"/>

        <Style x:Key="HeaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E65100"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BackgroundBrush}" CornerRadius="8" Effect="{StaticResource WindowShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" CornerRadius="8 8 0 0"
                    MouseLeftButtonDown="Border_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="Прохождение опроса" Foreground="White" FontSize="13" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                </Grid>
            </Border>

            <!-- Информация об опросе -->
            <Border Grid.Row="1" Background="White" Padding="20" Margin="0,0,0,1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="{Binding SurveyTitle}" FontSize="16" FontWeight="SemiBold" Foreground="#212121"/>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,5,0,0">
                        <TextBlock Text="{Binding Progress}" Foreground="#FF9800" FontWeight="SemiBold" FontSize="13"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Вопрос -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <Border Padding="30" MinHeight="300">
                    <StackPanel>
                        <!-- Номер и баллы -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="{Binding CurrentQuestion.OrderNumber, StringFormat='Вопрос {0}'}" 
                                       FontSize="20" FontWeight="SemiBold" Foreground="#212121"/>
                            <TextBlock Text="{Binding CurrentQuestion.Points, StringFormat=' ({0} бал.)'}" 
                                       FontSize="14" Foreground="#FF9800" VerticalAlignment="Bottom" Margin="5,0,0,0"/>
                        </StackPanel>

                        <!-- Текст вопроса -->
                        <TextBlock Text="{Binding CurrentQuestion.QuestionText}" FontSize="16" 
                                   Foreground="#424242" Margin="0,0,0,25" TextWrapping="Wrap"/>

                        <!-- Текстовый ответ -->
                        <TextBox Text="{Binding CurrentQuestion.TextAnswer, UpdateSourceTrigger=PropertyChanged}" 
                                 Height="150" Padding="15,10" Margin="0,0,0,20"
                                 BorderBrush="#E0E0E0" BorderThickness="1" TextWrapping="Wrap" AcceptsReturn="True"
                                 Visibility="{Binding CurrentQuestion.IsText, Converter={StaticResource BoolToVisibilityConverter}}"/>

                        <!-- Варианты ответов -->
                        <!-- Варианты ответов -->
                        <ContentControl Visibility="{Binding CurrentQuestion.IsChoice, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ContentControl.Style>
                                <Style TargetType="ContentControl">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentQuestion.IsSingleChoice}" Value="True">
                                            <Setter Property="ContentTemplate">
                                                <Setter.Value>
                                                    <DataTemplate>
                                                        <ItemsControl ItemsSource="{Binding DataContext.CurrentQuestion.Options, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <RadioButton IsChecked="{Binding IsSelected}" Margin="0,5"
                                                         GroupName="{Binding DataContext.CurrentQuestion.Id, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}">
                                                                        <TextBlock Text="{Binding Text}" FontSize="15" Margin="5,0,0,0"/>
                                                                    </RadioButton>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </DataTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentQuestion.IsMultipleChoice}" Value="True">
                                            <Setter Property="ContentTemplate">
                                                <Setter.Value>
                                                    <DataTemplate>
                                                        <ItemsControl ItemsSource="{Binding DataContext.CurrentQuestion.Options, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <CheckBox IsChecked="{Binding IsSelected}" Margin="0,5">
                                                                        <TextBlock Text="{Binding Text}" FontSize="15" Margin="5,0,0,0"/>
                                                                    </CheckBox>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </DataTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ContentControl.Style>
                        </ContentControl>
                    </StackPanel>
                </Border>
            </ScrollViewer>

            <!-- Навигация -->
            <Border Grid.Row="3" Background="White" Padding="15" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
                <Grid>
                    <Button Content="← Назад" Width="100" Height="36"
                                Background="Transparent" BorderBrush="#E0E0E0" BorderThickness="1" Cursor="Hand"
                                Command="{Binding PreviousQuestionCommand}"
                                Visibility="{Binding IsFirstQuestion, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}" Margin="295,0,375,0"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Вперёд →" Width="100" Height="36" Margin="0,0,10,0"
                                Background="Transparent" BorderBrush="#E0E0E0" BorderThickness="1" Cursor="Hand"
                                Command="{Binding NextQuestionCommand}"
                                Visibility="{Binding IsLastQuestion, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"/>

                        <Button Content="Завершить опрос" Width="150" Height="36" Margin="0,0,10,0"
                                Background="#4CAF50" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"
                                Command="{Binding FinishSurveyCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"/>

                        <Button Content="Выйти" Width="100" Height="36"
                                Background="Transparent" BorderBrush="#E53935" Foreground="#E53935" BorderThickness="1" Cursor="Hand"
                                Command="{Binding CancelCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>