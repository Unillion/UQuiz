<Window x:Class="UQuiz.views.StudentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:UQuiz.converters"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        
        <SolidColorBrush x:Key="PrimaryBrush" Color="#FF9800"/>
        <SolidColorBrush x:Key="SidebarBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#FAFAFA"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#E0E0E0"/>

        <Style x:Key="HeaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E65100"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource HeaderButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#424242"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="16,0,0,0"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFF3E0"/>
                                <Setter Property="Foreground" Value="#FF9800"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SurveyCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,12,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#FF9800"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="StudentSurveyCardTemplate">
            <Border Width="260" Style="{StaticResource SurveyCardStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="SemiBold" 
                       Foreground="#212121" Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding Description}" FontSize="12" 
                       Foreground="#757575" Margin="0,0,0,12" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Вопросов:" Foreground="#9E9E9E" FontSize="11"/>
                        <TextBlock Text="{Binding QuestionsCount}" Foreground="#FF9800" FontSize="11" 
                           FontWeight="SemiBold" Margin="4,0,12,0"/>
                        <TextBlock Text="Учитель:" Foreground="#9E9E9E" FontSize="11"/>
                        <TextBlock Text="{Binding TeacherName}" Foreground="#616161" FontSize="11" Margin="4,0,0,0"/>
                    </StackPanel>
                    <TextBlock Text="{Binding Score, StringFormat='Результат: {0}'}" FontSize="12" 
                       Foreground="#4CAF50" Margin="0,8,0,0" 
                       Visibility="{Binding Score, Converter={StaticResource StringToVisibilityConverter}}"/>
                    <Border Height="1" Background="#EEEEEE" Margin="0,10"/>
                    <TextBlock Text="{Binding CreatedDate, StringFormat='Создан: {0}'}" FontSize="10" 
                       Foreground="#9E9E9E" HorizontalAlignment="Right"/>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Border Background="{StaticResource BackgroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" 
                    MouseLeftButtonDown="Border_MouseLeftButtonDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                        <TextBlock Text="UQuiz" Foreground="White" FontSize="13" FontWeight="Bold"/>
                        <TextBlock Text="| Панель ученика" Foreground="#FFE0B2" FontSize="11" 
                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="&#xE921;" Style="{StaticResource HeaderButtonStyle}"
                                Command="{Binding MinimizeCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"/>
                        <Button Content="&#xE922;" Style="{StaticResource HeaderButtonStyle}"
                                Command="{Binding MaximizeCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"/>
                        <Button Content="&#xE711;" Style="{StaticResource CloseButtonStyle}"
                                Command="{Binding CloseCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Background="{StaticResource SidebarBrush}" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
                    <StackPanel>
                        <Border Padding="16" Margin="0,16,0,8">
                            <Border Padding="16" Margin="0,16,0,8">
                                <StackPanel>
                                    <TextBlock Text="Ученик" FontSize="15" FontWeight="SemiBold" Foreground="#212121"/>
                                    <TextBlock Text="{Binding FullName}" FontSize="13" Foreground="#616161" Margin="0,4,0,0"/>
                                    <TextBlock Text="{Binding StudentEmail}" FontSize="11" Foreground="#9E9E9E" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </Border>

                        <Border Height="1" Background="#E0E0E0" Margin="12,0"/>

                        <StackPanel Margin="12,16">
                            <Button Content="Доступные опросы" Style="{StaticResource MenuButtonStyle}" 
                                Command="{Binding NavigateCommand}" CommandParameter="Available"/>
                            <Button Content="Пройденные опросы" Style="{StaticResource MenuButtonStyle}" 
                                Command="{Binding NavigateCommand}" CommandParameter="Completed"/>
                            <Button Content="Мои учителя" Style="{StaticResource MenuButtonStyle}" 
                                Command="{Binding NavigateCommand}" CommandParameter="Teachers"/>
                            <Button Content="Заявки" Style="{StaticResource MenuButtonStyle}" 
                                Command="{Binding NavigateCommand}" CommandParameter="Requests"/>
                            <Button Content="Профиль" Style="{StaticResource MenuButtonStyle}" 
                                Command="{Binding NavigateCommand}" CommandParameter="Profile"/>
                        </StackPanel>

                        <Border Height="1" Background="#E0E0E0" Margin="12,8"/>

                        <Button Content="Выйти" Style="{StaticResource MenuButtonStyle}" 
                            Margin="12,16" 
                            Command="{Binding LogoutCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"/>
                    </StackPanel>
                </Border>

                <Grid Grid.Column="1" Background="{StaticResource BackgroundBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Padding="24,20,24,16">
                        <TextBlock x:Name="TxtPageTitle" Text="Доступные опросы" FontSize="20" 
                                   FontWeight="SemiBold" Foreground="#212121"/>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ContentControl Grid.Row="1" Content="{Binding SelectedMenu}">
                            <ContentControl.Resources>
                                <DataTemplate x:Key="Available">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding DataContext.AvailableSurveys, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}" 
                              ItemTemplate="{StaticResource StudentSurveyCardTemplate}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Margin="24,0,24,24"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </DataTemplate>

                                <DataTemplate x:Key="Completed">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding DataContext.CompletedSurveys, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}" 
                              ItemTemplate="{StaticResource StudentSurveyCardTemplate}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Margin="24,0,24,24"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </DataTemplate>

                                <DataTemplate x:Key="Requests">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel Margin="24">
                                            <TextBlock Text="Входящие заявки от учителей" FontSize="18" FontWeight="SemiBold" 
                       Foreground="#212121" Margin="0,0,0,15"/>

                                            <ItemsControl ItemsSource="{Binding DataContext.PendingRequests, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" 
                                Padding="16" Margin="0,0,0,10" Background="White">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding TeacherName}" FontSize="15" FontWeight="SemiBold"/>
                                                                    <TextBlock Text="{Binding TeacherEmail}" FontSize="12" Foreground="#757575" Margin="0,4,0,0"/>
                                                                    <TextBlock Text="{Binding OrganizationName, StringFormat='Организация: {0}'}" 
                                               FontSize="12" Foreground="#009688" Margin="0,8,0,0"/>
                                                                    <TextBlock Text="{Binding CreatedDate, StringFormat='Заявка от: {0}'}" FontSize="11" 
                                               Foreground="#9E9E9E" Margin="0,8,0,0"/>
                                                                </StackPanel>
                                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                                    <Button Content="Принять" Width="80" Height="32" Margin="0,0,10,0"
                                            Background="#4CAF50" Foreground="White" BorderThickness="0" Cursor="Hand"
                                            Command="{Binding DataContext.AcceptRequestCommand, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"
                                            CommandParameter="{Binding}">
                                                                        <Button.Resources>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="CornerRadius" Value="4"/>
                                                                            </Style>
                                                                        </Button.Resources>
                                                                    </Button>
                                                                    <Button Content="Отклонить" Width="80" Height="32"
                                            Background="#E53935" Foreground="White" BorderThickness="0" Cursor="Hand"
                                            Command="{Binding DataContext.RejectRequestCommand, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"
                                            CommandParameter="{Binding}">
                                                                        <Button.Resources>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="CornerRadius" Value="4"/>
                                                                            </Style>
                                                                        </Button.Resources>
                                                                    </Button>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </ScrollViewer>
                                </DataTemplate>

                                <DataTemplate x:Key="Profile">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <Border Padding="24">
                                            <StackPanel MaxWidth="500">
                                                <TextBlock Text="Редактирование профиля" FontSize="18" FontWeight="SemiBold" 
                           Foreground="#212121" Margin="0,0,0,20"/>

                                                <TextBlock Text="ФИО" Foreground="#616161" FontSize="13" 
                           FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                <TextBox Text="{Binding DataContext.FullName, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}, Mode=OneWay}" 
                         Height="36" Padding="12,8" Margin="0,0,0,20"
                         BorderBrush="#E0E0E0" BorderThickness="1" IsReadOnly="True" Background="#F5F5F5"/>

                                                <TextBlock Text="Email" Foreground="#616161" FontSize="13" 
                           FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                <TextBox Text="{Binding DataContext.StudentEmail, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}, Mode=OneWay}" 
                         Height="36" Padding="12,8" Margin="0,0,0,20"
                         BorderBrush="#E0E0E0" BorderThickness="1" IsReadOnly="True" Background="#F5F5F5"/>

                                                <TextBlock Text="Класс / Группа" Foreground="#616161" FontSize="13" 
                           FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                <TextBox Text="{Binding DataContext.StudentClass, UpdateSourceTrigger=PropertyChanged, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}" 
                         Height="36" Padding="12,8" Margin="0,0,0,20"
                         BorderBrush="#E0E0E0" BorderThickness="1"/>

                                                <TextBlock Text="{Binding DataContext.ProfileMessage, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}" 
                           Foreground="#4CAF50" FontSize="12" Margin="0,0,0,15"/>

                                                <Button Content="Сохранить" Width="120" Height="40"
                        Background="#FF9800" Foreground="White" BorderThickness="0" 
                        FontWeight="SemiBold" Cursor="Hand"
                        Command="{Binding DataContext.SaveProfileCommand, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}">
                                                    <Button.Resources>
                                                        <Style TargetType="Border">
                                                            <Setter Property="CornerRadius" Value="4"/>
                                                        </Style>
                                                    </Button.Resources>
                                                </Button>
                                            </StackPanel>
                                        </Border>
                                    </ScrollViewer>
                                </DataTemplate>

                                <DataTemplate x:Key="Teachers">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel Margin="24">
                                            <TextBlock Text="Мои учителя" FontSize="18" FontWeight="SemiBold" 
                       Foreground="#212121" Margin="0,0,0,15"/>

                                            <ItemsControl ItemsSource="{Binding DataContext.MyTeachers, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" 
                                Padding="16" Margin="0,0,12,12" Width="280" Background="White">
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" Foreground="#212121"/>
                                                                <TextBlock Text="{Binding Email}" FontSize="12" Foreground="#757575" Margin="0,4,0,0"/>
                                                                <TextBlock Text="{Binding Subject, StringFormat='Предмет: {0}'}" FontSize="12" 
                                           Foreground="#FF9800" Margin="0,8,0,0"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                            </ItemsControl>
                                        </StackPanel>
                                    </ScrollViewer>
                                </DataTemplate>
                            </ContentControl.Resources>

                            <ContentControl.Style>
                                <Style TargetType="ContentControl">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedMenu}" Value="Available">
                                            <Setter Property="ContentTemplate" Value="{StaticResource Available}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedMenu}" Value="Completed">
                                            <Setter Property="ContentTemplate" Value="{StaticResource Completed}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedMenu}" Value="Teachers">
                                            <Setter Property="ContentTemplate" Value="{StaticResource Teachers}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedMenu}" Value="Requests">
                                            <Setter Property="ContentTemplate" Value="{StaticResource Requests}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedMenu}" Value="Profile">
                                            <Setter Property="ContentTemplate" Value="{StaticResource Profile}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ContentControl.Style>
                        </ContentControl>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>