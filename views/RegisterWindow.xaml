<Window x:Class="UQuiz.views.RegisterWindow"
        xmlns:viewModels="clr-namespace:UQuiz.ViewModels"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:UQuiz.converters"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Height="1000" Width="1000">

    <Window.Resources>
        <!-- Конвертеры -->
        <converters:UserTypeToBoolConverter x:Key="UserTypeToBoolConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>

        <!-- Тени -->
        <DropShadowEffect x:Key="WindowShadow" BlurRadius="20" ShadowDepth="0" Opacity="0.25" Color="Black"/>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="15" ShadowDepth="2" Opacity="0.15" Color="Black"/>
        <DropShadowEffect x:Key="HoverShadow" BlurRadius="10" ShadowDepth="3" Opacity="0.2" Color="Black"/>

        <!-- Стиль для TextBox -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="#FAFAFA"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#3F51B5"/>
                                <Setter Property="BorderThickness" Value="2"/>
                                <Setter Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для PasswordBox -->
        <Style x:Key="ModernPasswordBox" TargetType="PasswordBox">
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="#FAFAFA"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#3F51B5"/>
                                <Setter Property="BorderThickness" Value="2"/>
                                <Setter Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для RadioButton -->
        <Style x:Key="RoleRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#616161"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,15,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="White" 
                                Padding="16,10" CornerRadius="25" BorderThickness="1" 
                                BorderBrush="#E0E0E0" Effect="{StaticResource CardShadow}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3F51B5"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#3F51B5"/>
                                <Setter Property="TextElement.FontWeight" Value="SemiBold"/>
                                <Setter Property="TextElement.Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#3F51B5"/>
                                <Setter TargetName="border" Property="Effect" Value="{StaticResource HoverShadow}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для кнопок заголовка -->
        <Style x:Key="HeaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A4FA0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для кнопки закрытия -->
        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource HeaderButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <!-- Основной контейнер -->
    <Border Background="#F5F7FA" CornerRadius="12" Effect="{StaticResource WindowShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Заголовок окна -->
            <Border Grid.Row="0" Background="#3F51B5" CornerRadius="12 12 0 0" 
                    MouseLeftButtonDown="Border_MouseLeftButtonDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0,0,0">
                        <TextBlock Text="UQuiz" Foreground="White" FontSize="14" FontWeight="Bold"/>
                        <TextBlock Text=" | Регистрация" Foreground="#B3C4F3" FontSize="12" 
                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="&#xE711;" Style="{StaticResource CloseButtonStyle}"
                                Command="{Binding CancelCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Основной контент - БЕЗ ScrollViewer -->
            <Grid Grid.Row="1" Margin="50,40">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- Левая сторона - информация -->
                <StackPanel VerticalAlignment="Center" Margin="0,0,40,0">
                    <TextBlock Text="Присоединяйтесь к UQuiz" FontSize="32" FontWeight="Light" 
                               Foreground="#3F51B5" Margin="0,0,0,15" TextWrapping="Wrap"/>
                    <TextBlock Text="Создайте аккаунт и начните использовать все возможности платформы" 
                               FontSize="15" Foreground="#616161" TextWrapping="Wrap" Margin="0,0,0,30"/>

                    <!-- Карточка с преимуществами -->
                    <Border Background="White" CornerRadius="16" Padding="25" 
                            >
                        <StackPanel>
                            <TextBlock Text="Возможности вашего аккаунта:" FontSize="14" 
                                       FontWeight="SemiBold" Foreground="#212121" Margin="0,0,0,15"/>

                            <StackPanel Margin="0,8,0,0">
                                <TextBlock Text="Учитель" FontWeight="SemiBold" Foreground="#3F51B5" Margin="0,0,0,5"/>
                                <TextBlock Text="• Создание опросов любой сложности" FontSize="13" Foreground="#616161" Margin="10,0,0,3"/>
                                <TextBlock Text="• Отправка ученикам и просмотр результатов" FontSize="13" Foreground="#616161" Margin="10,0,0,3"/>
                                <TextBlock Text="• Глубокая аналитика с графиками" FontSize="13" Foreground="#616161" Margin="10,0,0,0"/>
                            </StackPanel>

                            <StackPanel Margin="0,15,0,0">
                                <TextBlock Text="Ученик" FontWeight="SemiBold" Foreground="#FF9800" Margin="0,0,0,5"/>
                                <TextBlock Text="• Прохождение опросов от учителей" FontSize="13" Foreground="#616161" Margin="10,0,0,3"/>
                                <TextBlock Text="• Просмотр своих результатов" FontSize="13" Foreground="#616161" Margin="10,0,0,0"/>
                            </StackPanel>

                            <StackPanel Margin="0,15,0,0">
                                <TextBlock Text="Организация" FontWeight="SemiBold" Foreground="#009688" Margin="0,0,0,5"/>
                                <TextBlock Text="• Просмотр аналитики по учителям" FontSize="13" Foreground="#616161" Margin="10,0,0,3"/>
                                <TextBlock Text="• Статистика по опросам организации" FontSize="13" Foreground="#616161" Margin="10,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Правая сторона - форма регистрации -->
                <Border Grid.Column="1" Background="White" CornerRadius="16" 
                        Padding="35">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Создание аккаунта" FontSize="24" FontWeight="SemiBold" 
                                   Foreground="#212121" Margin="0,0,0,8"/>
                        <TextBlock Text="Заполните данные для регистрации" FontSize="14" 
                                   Foreground="#757575" Margin="0,0,0,25"/>

                        <!-- ФИО / Название организации -->
                        <TextBlock Text="{Binding FieldLabel}" Foreground="#616161" FontSize="13" 
                            FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding FullNameOrOrgName, UpdateSourceTrigger=PropertyChanged}" 
                            Style="{StaticResource ModernTextBox}" Margin="0,0,0,15"/>

                        <!-- Email -->
                        <TextBlock Text="Email" Foreground="#616161" FontSize="13" 
                                   FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource ModernTextBox}" Margin="0,0,0,15"/>

                        <!-- Пароль -->
                        <TextBlock Text="Пароль" Foreground="#616161" FontSize="13" 
                                   FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <PasswordBox x:Name="PasswordBox" Style="{StaticResource ModernPasswordBox}" 
                                     Margin="0,0,0,5" PasswordChanged="PasswordBox_PasswordChanged"/>
                        <TextBlock Text="Минимум 8 символов" FontSize="11" Foreground="#9E9E9E" 
                                   Margin="0,0,0,15"/>

                        <!-- Подтверждение пароля -->
                        <TextBlock Text="Подтвердите пароль" Foreground="#616161" FontSize="13" 
                                   FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <PasswordBox x:Name="ConfirmPasswordBox" Style="{StaticResource ModernPasswordBox}" 
                                     Margin="0,0,0,15" PasswordChanged="ConfirmPasswordBox_PasswordChanged"/>

                        <!-- Тип пользователя -->
                        <TextBlock Text="Тип аккаунта" Foreground="#616161" FontSize="13" 
                                   FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <WrapPanel Margin="0,0,0,15">
                            <RadioButton Content="Учитель" GroupName="Role"
                                         IsChecked="{Binding SelectedUserType, Converter={StaticResource UserTypeToBoolConverter}, ConverterParameter=Teacher}"
                                         />
                            <RadioButton Content="Ученик" GroupName="Role"
                                         IsChecked="{Binding SelectedUserType, Converter={StaticResource UserTypeToBoolConverter}, ConverterParameter=RegularUser}"
                                         />
                            <RadioButton Content="Организация" GroupName="Role"
                                         IsChecked="{Binding SelectedUserType, Converter={StaticResource UserTypeToBoolConverter}, ConverterParameter=Organization}"
                                         />
                        </WrapPanel>

                        <!-- Сообщение об ошибке -->
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="#E53935" 
                                   FontSize="13" Margin="0,10,0,0" TextWrapping="Wrap"/>

                        <!-- Кнопки -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                            <Button Content="Отмена" Width="100" Height="42" Margin="0,0,10,0"
                                    Background="Transparent" Foreground="#757575" 
                                    BorderBrush="#E0E0E0" BorderThickness="1" Cursor="Hand"
                                    Command="{Binding CancelCommand}"
                                    CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>

                            <Button Content="Зарегистрироваться" Width="160" Height="42"
                                    Background="#3F51B5" Foreground="White" BorderThickness="0" 
                                    FontWeight="SemiBold" Cursor="Hand"
                                    Command="{Binding RegisterCommand}"
                                    CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>