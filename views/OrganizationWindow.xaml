<Window x:Class="UQuiz.views.OrganizationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:UQuiz.converters"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <SolidColorBrush x:Key="PrimaryBrush" Color="#009688"/>
        <SolidColorBrush x:Key="SidebarBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#FAFAFA"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#E0E0E0"/>

        <Style x:Key="HeaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#00796B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource HeaderButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#424242"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="16,0,0,0"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E0F2F1"/>
                                <Setter Property="Foreground" Value="#009688"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Шаблон для учителя -->
        <DataTemplate x:Key="TeacherTemplate">
            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" 
                    Padding="16" Margin="0,0,12,12" Width="260" Background="White">
                <StackPanel>
                    <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" Foreground="#212121"/>
                    <TextBlock Text="{Binding Email}" FontSize="12" Foreground="#757575" Margin="0,4,0,0"/>
                    <TextBlock Text="{Binding Subject, StringFormat='Предмет: {0}'}" FontSize="12" 
                               Foreground="#009688" Margin="0,8,0,0"/>
                    <TextBlock Text="{Binding SurveysCount, StringFormat='Опросов: {0}'}" FontSize="12" 
                               Foreground="#616161" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Шаблон для опроса -->
        <DataTemplate x:Key="SurveyCardTemplate">
            <Border Width="260" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" 
                    Padding="16" Margin="0,0,12,12" Background="White">
                <StackPanel>
                    <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="SemiBold" Foreground="#212121"/>
                    <TextBlock Text="{Binding Description}" FontSize="12" Foreground="#757575" Margin="0,4,0,0"/>
                    <TextBlock Text="{Binding TeacherName, StringFormat='Учитель: {0}'}" FontSize="12" 
                               Foreground="#009688" Margin="0,8,0,0"/>
                    <TextBlock Text="{Binding QuestionsCount, StringFormat='Вопросов: {0}'}" FontSize="12" 
                               Foreground="#616161" Margin="0,4,0,0"/>
                    <TextBlock Text="{Binding CreatedDate, StringFormat='Создан: {0}'}" FontSize="11" 
                               Foreground="#9E9E9E" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Шаблон для заявки -->
        <DataTemplate x:Key="RequestTemplate">
            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" 
                    Padding="16" Margin="0,0,12,12" Width="280" Background="White">
                <StackPanel>
                    <TextBlock Text="{Binding TeacherName}" FontSize="15" FontWeight="SemiBold" Foreground="#212121"/>
                    <TextBlock Text="{Binding TeacherEmail}" FontSize="12" Foreground="#757575" Margin="0,4,0,0"/>
                    <TextBlock Text="{Binding StatusText, StringFormat='Статус: {0}'}" FontSize="12" 
                               Foreground="#FF9800" Margin="0,8,0,0"/>
                    <TextBlock Text="{Binding CreatedDate, StringFormat='Отправлена: {0}'}" FontSize="11" 
                               Foreground="#9E9E9E" Margin="0,4,0,0"/>
                    <Button Content="Отменить" Width="100" Height="32" Margin="0,12,0,0"
                            Background="#E53935" Foreground="White" BorderThickness="0" Cursor="Hand"
                            Command="{Binding DataContext.CancelRequestCommand, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"
                            CommandParameter="{Binding}"
                            Visibility="{Binding Status, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Pending}"/>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Border Background="{StaticResource BackgroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" 
                    MouseLeftButtonDown="Border_MouseLeftButtonDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                        <TextBlock Text="UQuiz" Foreground="White" FontSize="13" FontWeight="Bold"/>
                        <TextBlock Text="| Панель организации" Foreground="#B2DFDB" FontSize="11" 
                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="&#xE921;" Style="{StaticResource HeaderButtonStyle}"
                                Command="{Binding MinimizeCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"/>
                        <Button Content="&#xE922;" Style="{StaticResource HeaderButtonStyle}"
                                Command="{Binding MaximizeCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"/>
                        <Button Content="&#xE711;" Style="{StaticResource CloseButtonStyle}"
                                Command="{Binding CloseCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Background="{StaticResource SidebarBrush}" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
                    <StackPanel>
                        <Border Padding="16" Margin="0,16,0,8">
                            <StackPanel>
                                <TextBlock Text="Организация" FontSize="15" FontWeight="SemiBold" Foreground="#212121"/>
                                <TextBlock Text="{Binding OrganizationName}" FontSize="13" 
                                           Foreground="#616161" Margin="0,4,0,0"/>
                                <TextBlock Text="{Binding OrganizationEmail}" FontSize="11" 
                                           Foreground="#9E9E9E" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Height="1" Background="#E0E0E0" Margin="12,0"/>

                        <StackPanel Margin="12,16">
                            <Button Content="Аналитика" Style="{StaticResource MenuButtonStyle}" 
                                Command="{Binding NavigateCommand}" CommandParameter="Analytics"/>
                            <Button Content="Учителя" Style="{StaticResource MenuButtonStyle}" 
                                Command="{Binding NavigateCommand}" CommandParameter="Teachers"/>
                            <Button Content="Заявки" Style="{StaticResource MenuButtonStyle}" 
                                Command="{Binding NavigateCommand}" CommandParameter="Requests"/>
                        </StackPanel>

                        <Border Height="1" Background="#E0E0E0" Margin="12,8"/>

                        <Button Content="Выйти" Style="{StaticResource MenuButtonStyle}" 
                                Margin="12,16" 
                                Command="{Binding LogoutCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"/>
                    </StackPanel>
                </Border>

                <Grid Grid.Column="1" Background="{StaticResource BackgroundBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Padding="24,20,24,16">
                        <TextBlock Text="{Binding PageTitle}" FontSize="20" 
                                   FontWeight="SemiBold" Foreground="#212121"/>
                    </Border>

                    <ContentControl Grid.Row="1" Content="{Binding SelectedMenu}">
                        <ContentControl.Resources>
                            <DataTemplate x:Key="Analytics">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel Margin="24">
                                        <!-- Общая сводка -->
                                        <WrapPanel Margin="0,0,0,20">
                                            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" 
                        Padding="20" Margin="0,0,15,15" Width="200">
                                                <StackPanel>
                                                    <TextBlock Text="Всего учителей" FontSize="12" Foreground="#757575"/>
                                                    <TextBlock Text="{Binding DataContext.OrganizationAnalytics.TotalTeachers, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}" 
                                   FontSize="28" FontWeight="Bold" Foreground="#009688"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" 
                        Padding="20" Margin="0,0,15,15" Width="200">
                                                <StackPanel>
                                                    <TextBlock Text="Всего опросов" FontSize="12" Foreground="#757575"/>
                                                    <TextBlock Text="{Binding DataContext.OrganizationAnalytics.TotalSurveys, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}" 
                                   FontSize="28" FontWeight="Bold" Foreground="#3F51B5"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" 
                        Padding="20" Margin="0,0,15,15" Width="200">
                                                <StackPanel>
                                                    <TextBlock Text="Всего учеников" FontSize="12" Foreground="#757575"/>
                                                    <TextBlock Text="{Binding DataContext.OrganizationAnalytics.TotalStudents, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}" 
                                   FontSize="28" FontWeight="Bold" Foreground="#FF9800"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" 
                        Padding="20" Margin="0,0,15,15" Width="200">
                                                <StackPanel>
                                                    <TextBlock Text="Средний балл" FontSize="12" Foreground="#757575"/>
                                                    <TextBlock Text="{Binding DataContext.OrganizationAnalytics.OverallAverageScore, StringFormat=N1, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}" 
                                   FontSize="28" FontWeight="Bold" Foreground="#4CAF50"/>
                                                </StackPanel>
                                            </Border>
                                        </WrapPanel>

                                        <!-- Статистика по учителям -->
                                        <TextBlock Text="Статистика по учителям" FontWeight="SemiBold" FontSize="18" 
                       Foreground="#212121" Margin="0,0,0,15"/>

                                        <ItemsControl ItemsSource="{Binding DataContext.TeacherStats, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" 
                                Padding="16" Margin="0,0,12,12" Width="280" Background="White">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding TeacherName}" FontSize="15" FontWeight="SemiBold" Foreground="#212121"/>
                                                            <TextBlock Text="{Binding Subject, StringFormat='Предмет: {0}'}" FontSize="12" 
                                           Foreground="#009688" Margin="0,4,0,0"/>
                                                            <Border Height="1" Background="#EEEEEE" Margin="0,8"/>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="Опросов:" FontSize="11" Foreground="#757575"/>
                                                                <TextBlock Text="{Binding SurveysCount}" FontSize="11" FontWeight="SemiBold" 
                                               Foreground="#3F51B5" Margin="5,0,15,0"/>
                                                                <TextBlock Text="Учеников:" FontSize="11" Foreground="#757575"/>
                                                                <TextBlock Text="{Binding StudentsCount}" FontSize="11" FontWeight="SemiBold" 
                                               Foreground="#FF9800" Margin="5,0,0,0"/>
                                                            </StackPanel>
                                                            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                                <TextBlock Text="Средний балл:" FontSize="11" Foreground="#757575"/>
                                                                <TextBlock Text="{Binding AverageScore, StringFormat=N1}" FontSize="11" 
                                               FontWeight="SemiBold" Foreground="#4CAF50" Margin="5,0,15,0"/>
                                                                <TextBlock Text="Пройдено:" FontSize="11" Foreground="#757575"/>
                                                                <TextBlock Text="{Binding CompletedSurveys}" FontSize="11" FontWeight="SemiBold" 
                                               Foreground="#009688" Margin="5,0,0,0"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                    </StackPanel>
                                </ScrollViewer>
                            </DataTemplate>

                            <DataTemplate x:Key="Teachers">
                                <Grid Margin="24">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- Поиск по email -->
                                    <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="16">
                                        <StackPanel>
                                            <TextBlock Text="Поиск учителя по Email" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBox Text="{Binding DataContext.SearchEmail, UpdateSourceTrigger=PropertyChanged, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}" 
                             Width="300" Height="36" Padding="10,8" Margin="0,0,10,0"
                             BorderBrush="#E0E0E0" BorderThickness="1"/>
                                                <Button Content="Найти" Width="100" Height="36"
                            Background="#009688" Foreground="White" BorderThickness="0" Cursor="Hand"
                            Command="{Binding DataContext.SearchTeacherCommand, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}">
                                                    <Button.Resources>
                                                        <Style TargetType="Border">
                                                            <Setter Property="CornerRadius" Value="4"/>
                                                        </Style>
                                                    </Button.Resources>
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Результаты поиска -->
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="200" Margin="0,16,0,0">
                                        <ItemsControl ItemsSource="{Binding DataContext.SearchResults, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" 
                                                        Padding="16" Margin="0,0,0,10" Background="White">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"/>
                                                                <TextBlock Text="{Binding Email}" FontSize="12" Foreground="#757575"/>
                                                                <TextBlock Text="{Binding Subject, StringFormat='Предмет: {0}'}" FontSize="12" Foreground="#009688" Margin="0,4,0,0"/>
                                                            </StackPanel>
                                                            <Button Grid.Column="1" Content="Отправить заявку" Width="150" Height="36"
                                                                Background="#009688" Foreground="White" BorderThickness="0" Cursor="Hand"
                                                                Command="{Binding DataContext.SendRequestCommand, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"
                                                                CommandParameter="{Binding}">
                                                                <Button.Resources>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="CornerRadius" Value="4"/>
                                                                    </Style>
                                                                </Button.Resources>
                                                            </Button>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <!-- Все учителя -->
                                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" MaxHeight="250" Margin="0,16,0,0">
                                        <StackPanel>
                                            <TextBlock Text="Все учителя в системе" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                            <ItemsControl ItemsSource="{Binding DataContext.AllTeachers, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}" 
                                                ItemTemplate="{StaticResource TeacherTemplate}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                            </ItemsControl>
                                        </StackPanel>
                                    </ScrollViewer>

                                    <!-- Мои учителя -->
                                    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Margin="0,16,0,0">
                                        <StackPanel>
                                            <TextBlock Text="Прикреплённые учителя" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                            <ItemsControl ItemsSource="{Binding DataContext.MyTeachers, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}" 
                                                ItemTemplate="{StaticResource TeacherTemplate}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                            </ItemsControl>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Grid>
                            </DataTemplate>

                            <DataTemplate x:Key="Surveys">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding DataContext.Surveys, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}" 
                                                  ItemTemplate="{StaticResource SurveyCardTemplate}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Margin="24,0,24,24"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </ScrollViewer>
                            </DataTemplate>

                            <DataTemplate x:Key="Requests">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding DataContext.SentRequests, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}" 
                                                  ItemTemplate="{StaticResource RequestTemplate}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Margin="24,0,24,24"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </ScrollViewer>
                            </DataTemplate>
                        </ContentControl.Resources>

                        <ContentControl.Style>
                            <Style TargetType="ContentControl">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedMenu}" Value="Analytics">
                                        <Setter Property="ContentTemplate" Value="{StaticResource Analytics}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedMenu}" Value="Teachers">
                                        <Setter Property="ContentTemplate" Value="{StaticResource Teachers}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedMenu}" Value="Surveys">
                                        <Setter Property="ContentTemplate" Value="{StaticResource Surveys}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedMenu}" Value="Requests">
                                        <Setter Property="ContentTemplate" Value="{StaticResource Requests}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ContentControl.Style>
                    </ContentControl>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>