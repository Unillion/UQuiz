<Window x:Class="UQuiz.views.SurveyBuilderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:UQuiz.converters"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Height="700" Width="900">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <SolidColorBrush x:Key="PrimaryBrush" Color="#3F51B5"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#FAFAFA"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#E0E0E0"/>

        <DropShadowEffect x:Key="WindowShadow" BlurRadius="20" ShadowDepth="0" Opacity="0.25" Color="Black"/>

        <Style x:Key="HeaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#32408F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource HeaderButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BackgroundBrush}" CornerRadius="8" Effect="{StaticResource WindowShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" CornerRadius="8 8 0 0"
                    MouseLeftButtonDown="Border_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="Конструктор опроса" Foreground="White" FontSize="13" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="&#xE711;" Style="{StaticResource CloseButtonStyle}"
                                Command="{Binding CancelCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Название опроса" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" 
                         Height="32" Padding="10,6" Margin="0,0,0,15"
                         BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>

                <TextBlock Grid.Row="1" Text="Описание" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox Grid.Row="1" Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" 
                         Height="60" Padding="10,6" Margin="0,0,0,15"
                         BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                         TextWrapping="Wrap" AcceptsReturn="True"/>

                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
                    <Button Content="+ Добавить вопрос" Width="140" Height="36"
                            Background="{StaticResource PrimaryBrush}" Foreground="White" BorderThickness="0"
                            Command="{Binding AddQuestionCommand}">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>

                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Questions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" 
                                        CornerRadius="6" Padding="15" Margin="0,0,0,10" Background="White">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <TextBlock Text="{Binding OrderNumber, StringFormat='Вопрос {0}'}" 
                                                       FontWeight="SemiBold" FontSize="14" Margin="0,0,15,0"/>
                                            <Button Content="✕ Удалить" Background="Transparent" 
                                                    BorderThickness="0" Foreground="#E53935" Cursor="Hand"
                                                    Command="{Binding DataContext.RemoveQuestionCommand, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="4"/>
                                                    </Style>
                                                </Button.Resources>
                                            </Button>
                                        </StackPanel>

                                        <TextBlock Text="Текст вопроса" FontSize="12" Foreground="#616161" Margin="0,0,0,5"/>
                                        <TextBox Text="{Binding QuestionText, UpdateSourceTrigger=PropertyChanged}" 
                                                 Height="32" Padding="10,6" Margin="0,0,0,10"
                                                 BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>

                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <StackPanel Width="200" Margin="0,0,15,0">
                                                <TextBlock Text="Тип вопроса" FontSize="12" Foreground="#616161"/>
                                                <ComboBox SelectedValuePath="Tag" SelectedValue="{Binding QuestionType}" Height="32">
                                                    <ComboBoxItem Content="Текстовый ответ" Tag="Text"/>
                                                    <ComboBoxItem Content="Один правильный ответ" Tag="SingleChoice"/>
                                                    <ComboBoxItem Content="Несколько правильных ответов" Tag="MultipleChoice"/>
                                                </ComboBox>
                                            </StackPanel>
                                            <StackPanel Width="100">
                                                <TextBlock Text="Баллы" FontSize="12" Foreground="#616161"/>
                                                <TextBox Text="{Binding Points, UpdateSourceTrigger=PropertyChanged}" 
                                                         Height="32" Padding="10,6"
                                                         BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Visibility="{Binding HasOptions, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                                <TextBlock Text="Варианты ответов" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding QuestionType}" Foreground="Red" FontWeight="Bold"/>
                                                <Button Content="+ Добавить вариант" Background="Transparent" 
                                                        BorderThickness="0" Foreground="{StaticResource PrimaryBrush}"
                                                        Margin="15,0,0,0" Cursor="Hand"
                                                        Command="{Binding AddOptionCommand}"/>
                                            </StackPanel>

                                            <TextBlock Text="Отметьте ОДИН правильный вариант" FontSize="11" Foreground="#757575" 
                                                       Margin="0,0,0,8" 
                                                       Visibility="{Binding IsSingleChoice, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                            <TextBlock Text="Отметьте один или НЕСКОЛЬКО правильных вариантов" 
                                                       FontSize="11" Foreground="#757575" Margin="0,0,0,8" 
                                                       Visibility="{Binding IsMultipleChoice, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                            <ItemsControl ItemsSource="{Binding Options}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,8">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <ContentControl Grid.Column="0" Margin="0,0,10,0" VerticalAlignment="Center">
                                                                <ContentControl.Style>
                                                                    <Style TargetType="ContentControl">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding DataContext.IsSingleChoice, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ItemsControl}}}" Value="True">
                                                                                <Setter Property="ContentTemplate">
                                                                                    <Setter.Value>
                                                                                        <DataTemplate>
                                                                                            <RadioButton IsChecked="{Binding DataContext.IsCorrect, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Grid}}}"
                                             GroupName="{Binding DataContext.OrderNumber, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ItemsControl}}}"/>
                                                                                        </DataTemplate>
                                                                                    </Setter.Value>
                                                                                </Setter>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding DataContext.IsMultipleChoice, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ItemsControl}}}" Value="True">
                                                                                <Setter Property="ContentTemplate">
                                                                                    <Setter.Value>
                                                                                        <DataTemplate>
                                                                                            <CheckBox IsChecked="{Binding DataContext.IsCorrect, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Grid}}}"/>
                                                                                        </DataTemplate>
                                                                                    </Setter.Value>
                                                                                </Setter>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </ContentControl.Style>
                                                            </ContentControl>

                                                            <TextBox Grid.Column="1" Text="{Binding OptionText, UpdateSourceTrigger=PropertyChanged}" 
                         Width="250" Height="28" Padding="8,4"
                         BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>

                                                            <TextBox Grid.Column="2" Text="{Binding Points, UpdateSourceTrigger=PropertyChanged}" 
                         Width="60" Height="28" Padding="5,4" Margin="10,0,0,0"
                         BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                         Visibility="{Binding DataContext.IsMultipleChoice, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ItemsControl}}, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                                            <Button Grid.Column="3" Content="✕" Background="Transparent" BorderThickness="0" 
                        Foreground="#E53935" Cursor="Hand" Margin="10,0,0,0"
                        Command="{Binding DataContext.RemoveOptionCommand, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"
                        CommandParameter="{Binding}"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Кнопки -->
                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                    <Button Content="Отмена" Width="100" Height="36" Margin="0,0,10,0"
                            Background="Transparent" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            Command="{Binding CancelCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"/>
                    <Button Content="Сохранить опрос" Width="140" Height="36"
                            Background="{StaticResource PrimaryBrush}" Foreground="White" BorderThickness="0"
                            Command="{Binding SaveSurveyCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>