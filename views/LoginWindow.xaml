<Window x:Class="UQuiz.LoginWindow"
        xmlns:viewModels="clr-namespace:UQuiz.ViewModels"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:UQuiz.converters"
        xmlns:local="clr-namespace:UQuiz"
        mc:Ignorable="d"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Height="600" Width="800">

    <Window.DataContext>
        <viewModels:LoginViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <!-- Конвертеры -->
        <converters:UserTypeToBoolConverter x:Key="UserTypeToBoolConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>

        <DropShadowEffect x:Key="WindowShadow" BlurRadius="15" ShadowDepth="0" Opacity="0.2" Color="Black"/>

        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#757575"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="Content" Value="&#xE711;"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="#FAFAFA" CornerRadius="8" Effect="{StaticResource WindowShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#3F51B5" CornerRadius="8 8 0 0" MouseLeftButtonDown="Border_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="UQuiz" Foreground="White"
                               VerticalAlignment="Center" Margin="12,0,0,0" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="&#xE921;" Command="{Binding MinimizeCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"/>
                        <Button Content="&#xE711;" Command="{Binding CloseCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="40">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center" Margin="0,0,40,0">
                    <TextBlock Text="PLACEHOLDER" FontSize="28" FontWeight="Light" 
                               Foreground="#3F51B5" TextWrapping="Wrap"/>
                    <TextBlock Text="Платформа для опросов и глубокой аналитики успеваемости" 
                               FontSize="14" Foreground="#757575" Margin="0,15,0,0" TextWrapping="Wrap"/>

                    <Border Background="#F5F5F5" CornerRadius="30" Padding="15" Margin="0,40,0,0">
                        <StackPanel>
                            <TextBlock Text="ВОЙТИ КАК:" FontSize="12" Foreground="#757575" Margin="0,0,0,10"/>
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Content="Учитель" GroupName="Role" 
                                    IsChecked="{Binding SelectedUserType, Converter={StaticResource UserTypeToBoolConverter}, ConverterParameter=Teacher}"/>
                                <RadioButton Content="Ученик" GroupName="Role" 
                                    IsChecked="{Binding SelectedUserType, Converter={StaticResource UserTypeToBoolConverter}, ConverterParameter=RegularUser}"/>
                                <RadioButton Content="Организация" GroupName="Role" 
                                    IsChecked="{Binding SelectedUserType, Converter={StaticResource UserTypeToBoolConverter}, ConverterParameter=Organization}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="30">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Добро пожаловать" FontSize="22" FontWeight="SemiBold" Foreground="#212121" Margin="0,0,0,5"/>
                        <TextBlock Text="Введите данные вашей учетной записи" FontSize="12" Foreground="#757575" Margin="0,0,0,30"/>

                        <TextBlock Text="Email" Foreground="#757575" FontSize="12" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource ModernTextBox}"/>

                        <TextBlock Text="Пароль" Foreground="#757575" FontSize="12" Margin="0,15,0,5"/>
                        <PasswordBox x:Name="TxtPassword" Style="{StaticResource ModernPasswordBox}" 
                                     PasswordChanged="TxtPassword_PasswordChanged"/>

                        <Button Content="Войти в систему" Height="40" Margin="0,30,0,0" 
                                Background="#3F51B5" Foreground="White" BorderThickness="0" 
                                FontWeight="SemiBold" Cursor="Hand" Command="{Binding LoginCommand}">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </Button.Resources>
                        </Button>

                        <!-- Индикатор ошибки -->
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="#E53935" 
                            FontSize="12" Margin="0,10,0,0" TextWrapping="Wrap"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

                        <TextBlock TextAlignment="Center" Margin="0,20,0,0">
                            <Hyperlink Command="{Binding RegisterCommand}">Нет аккаунта? Зарегистрироваться</Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>